# Geoserve — environment defaults.  Copy to `.env`; the defaults below
# make `docker compose up -d --build` work from a fresh clone.

# ── pgstac Postgres ───────────────────────────────────────────────────
# `pgdb` matches the bundled DB service in docker-compose.yml.  Point
# PG_HOST at your own pgstac container name if you're embedding geoserve
# into a larger stack (then run `docker compose up titiler tipg stac-api`
# to skip the bundled DB).
PG_HOST=pgdb
PG_PORT=5432
PG_USER=postgres
PG_PASSWORD=pgstac_local
PG_DBNAME=pgstac

# ── COG storage ────────────────────────────────────────────────────────
# Host path bind-mounted into titiler as /cogs.
# STAC items in pgstac.items reference files here via file:///cogs/...
COGS_HOST_DIR=./data/cogs

# ── Networking ─────────────────────────────────────────────────────────
# When embedded, set this to the parent stack's docker network so the
# services share container DNS with the parent's services.
# When running standalone, leave default and geoserve creates its own.
# GEOSERVE_NETWORK=my_project_network

# ── Container naming ───────────────────────────────────────────────────
# Override these in a parent project to prefix names so multiple geoserve
# stacks can run on the same host without collision.
# PGDB_CONTAINER=myproj-pgdb
# STACAPI_CONTAINER=myproj-stacapi
# TITILER_CONTAINER=myproj-titiler
# TIPG_CONTAINER=myproj-tipg

# ── tipg schemas ───────────────────────────────────────────────────────
# JSON-array literal: which Postgres schemas tipg should auto-discover.
# TIPG_SCHEMAS=["public"]

# ── Tuning (sensible defaults baked into docker-compose.yml) ──────────
# TITILER_WORKERS=4
# TITILER_MEM_LIMIT=1500m
# GDAL_CACHEMAX=75%
